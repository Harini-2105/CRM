{
  "entities": {
    "Organization": {
      "title": "Organization",
      "description": "Represents a tenant in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the organization." },
        "createdAt": { "type": "string", "format": "date-time" },
        "branding": {
          "type": "object",
          "properties": {
            "logoUrl": { "type": "string" },
            "colors": { "type": "object" }
          }
        }
      },
      "required": ["name", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "System user with organization affiliation and roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "orgId": { "type": "string", "description": "Reference to the organization." },
        "role": { "type": "string", "enum": ["super_admin", "org_admin", "manager", "sales_rep", "support_rep", "viewer"] },
        "status": { "type": "string", "enum": ["active", "inactive", "deleted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "orgId", "role", "status", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential customer to be qualified.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "ownerId": { "type": "string" },
        "score": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "email", "status", "createdAt"]
    },
    "Deal": {
      "title": "Deal",
      "description": "A sales opportunity in the pipeline.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "title": { "type": "string" },
        "value": { "type": "number" },
        "currency": { "type": "string" },
        "pipelineId": { "type": "string" },
        "stageId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "won", "lost"] },
        "ownerId": { "type": "string" },
        "contactId": { "type": "string" },
        "companyId": { "type": "string" },
        "expectedCloseDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "title", "pipelineId", "stageId", "status", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A piece of work to be completed.",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "assigneeId": { "type": "string" },
        "linkedEntityType": { "type": "string" },
        "linkedEntityId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "title", "status", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Recorded interaction (call, meeting, email).",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" },
        "linkedEntityType": { "type": "string" },
        "linkedEntityId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "type", "timestamp"]
    }
  },
  "firestore": {
    "organizations": { "schema": "Organization", "description": "Global settings for each tenant." },
    "users": { "schema": "User", "description": "User profiles and organization membership." },
    "leads": { "schema": "Lead", "description": "Sales leads for each organization." },
    "deals": { "schema": "Deal", "description": "Revenue opportunities." },
    "tasks": { "schema": "Task", "description": "Operational tasks." },
    "activities": { "schema": "Activity", "description": "History of interactions." }
  }
}
